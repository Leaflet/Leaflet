{
  "name": "leaflet",
  "version": "2.0.0-alpha.1",
  "homepage": "https://leafletjs.com/",
  "description": "JavaScript library for mobile-friendly interactive maps",
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.5.0",
    "@eslint/compat": "^2.1.0",
    "@eslint/css": "^1.2.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "bundlemon": "^3.1.0",
    "chai": "^6.2.2",
    "eslint": "^10.5.0",
    "eslint-config-mourner": "^4.1.0",
    "eslint-plugin-baseline-js": "^0.6.2",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import-x": "^4.16.2",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "leafdoc": "^2.4.0",
    "lint-staged": "^17.0.5",
    "playwright": "^1.60.0",
    "prosthetic-hand": "^2.2.2",
    "rollup": "^4.60.4",
    "sinon": "^22.0.0",
    "ssri": "^14.0.0",
    "ui-event-simulator": "^2.0.0",
    "vitest": "^4.1.7"
  },
  "type": "module",
  "exports": {
    ".": "./dist/leaflet-src.js",
    "./styles.css": "./dist/leaflet.css"
  },
  "style": "dist/leaflet.css",
  "files": [
    "dist",
    "src",
    "!dist/leaflet.zip",
    "!*.leafdoc",
    "CHANGELOG.md"
  ],
  "scripts": {
    "debug": "http-server -c-1",
    "docs": "node ./build/docs.js && node ./build/integrity.js",
    "test": "vitest --project=chromium",
    "test:ui": "vitest --project=chromium --ui --browser.headless=false",
    "coverage": "vitest --run --project=chromium --coverage",
    "build": "rollup --config build/rollup-config.js",
    "watch": "npm run build -- --watch",
    "lint": "eslint . --cache",
    "lintfix": "npm run lint -- --fix",
    "bundlemon": "bundlemon",
    "serve": "cd docs && bundle exec jekyll serve",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/Leaflet/Leaflet.git"
  },
  "keywords": [
    "gis",
    "map"
  ],
  "license": "BSD-2-Clause",
  "lint-staged": {
    "*.(js|mjs|md)": "eslint --cache --fix"
  }
}
